{
	"buildCommand": "npm run build",
	"outputDirectory": "frontend/dist",
	"framework": "vite",
	"cleanUrls": true,
	"rewrites": [
		{ "source": "/api/(.*)", "destination": "/api/$1" },
		{ "source": "/(.*)", "destination": "/index.html" }
	],
	"functions": {
		"api/**/*.js": {
			"maxDuration": 60
		}
	}
}
